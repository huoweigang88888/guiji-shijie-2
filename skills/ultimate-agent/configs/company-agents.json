{
  "name": "公司场景多智能体系统",
  "version": "1.0.0",
  "description": "企业级多智能体协作系统，覆盖完整业务流程",
  "created": "2026-03-18",
  "orchestrator": {
    "name": "CEO-Agent",
    "role": "首席执行官/协调者",
    "description": "战略决策、任务分发、资源协调",
    "capabilities": [
      "战略规划",
      "任务分解",
      "资源分配",
      "进度跟踪",
      "风险管理"
    ],
    "model": "bailian/qwen3.5-plus",
    "priority": "high"
  },
  "agents": [
    {
      "id": "agent-pm",
      "name": "产品经理代理",
      "role": "Product Manager",
      "description": "需求分析、PRD 撰写、用户调研",
      "capabilities": [
        "需求收集",
        "竞品分析",
        "PRD 撰写",
        "用户故事",
        "优先级排序"
      ],
      "model": "bailian/qwen3.5-plus",
      "workspace": "workspaces/product-manager",
      "triggers": [
        "新需求",
        "产品规划",
        "用户反馈"
      ]
    },
    {
      "id": "agent-architect",
      "name": "架构师代理",
      "role": "System Architect",
      "description": "技术选型、架构设计、代码审查",
      "capabilities": [
        "技术选型",
        "架构设计",
        "API 设计",
        "数据库设计",
        "安全审查"
      ],
      "model": "bailian/qwen3.5-plus",
      "workspace": "workspaces/architect",
      "triggers": [
        "技术方案",
        "架构评审",
        "代码审查"
      ]
    },
    {
      "id": "agent-senior-dev",
      "name": "高级开发代理",
      "role": "Senior Developer",
      "description": "核心代码实现、性能优化",
      "capabilities": [
        "代码实现",
        "性能优化",
        "代码审查",
        "单元测试",
        "CI/CD"
      ],
      "model": "bailian/qwen3.5-plus",
      "workspace": "workspaces/senior-dev",
      "triggers": [
        "开发任务",
        "代码实现",
        "性能问题"
      ]
    },
    {
      "id": "agent-ui-designer",
      "name": "UI 设计师代理",
      "role": "UI/UX Designer",
