  "workflows": [
    {
      "name": "新产品开发流程",
      "id": "workflow-new-product",
      "steps": [
        {
          "agent": "agent-pm",
          "task": "需求分析和 PRD"
        },
        {
          "agent": "agent-architect",
          "task": "技术方案设计"
        },
        {
          "agent": "agent-ui-designer",
          "task": "界面设计"
        },
        {
          "agent": "agent-senior-dev",
          "task": "代码实现"
        },
        {
          "agent": "agent-qa",
          "task": "测试验证"
        },
        {
          "agent": "agent-devops",
          "task": "部署上线"
        }
      ]
    },
    {
      "name": "Bug 修复流程",
      "id": "workflow-bug-fix",
      "steps": [
        {
          "agent": "agent-qa",
          "task": "Bug 复现和定位"
        },
        {
          "agent": "agent-senior-dev",
          "task": "代码修复"
        },
        {
          "agent": "agent-qa",
          "task": "回归测试"
        },
        {
          "agent": "agent-devops",
          "task": "热修复部署"
        }
      ]
    },
    {
      "name": "数据分析流程",
      "id": "workflow-data-analysis",
      "steps": [
        {
          "agent": "agent-data",
          "task": "数据收集和清洗"
        },
        {
          "agent": "agent-data",
          "task": "统计分析"
        },
        {
          "agent": "agent-data",
          "task": "可视化报表"
        },
        {
          "agent": "agent-pm",
          "task": "业务洞察解读"
        }
      ]
    },
    {
      "name": "招聘流程",
      "id": "workflow-hiring",
      "steps": [
        {
          "agent": "agent-hr",
          "task": "职位发布和简历筛选"
        },
        {
          "agent": "agent-hr",
          "task": "面试安排"
        },
        {
          "agent": "agent-senior-dev",
          "task": "技术面试"
        },
        {
          "agent": "agent-hr",
          "task": "Offer 发放"
        }
      ]
    }
  ],
  "communication": {
    "channels": [
      "webchat",
      "discord",
      "telegram"
    ],
    "broadcast_on_completion": true,
    "daily_standup": "09:00",
    "weekly_report": "Friday 18:00"
  },
  "memory": {
    "shared_knowledge_base": "workspaces/shared/knowledge",
    "project_memories": "workspaces/{agent_id}/memory",
    "retention_days": 90
  }
}