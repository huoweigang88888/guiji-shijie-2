# 硅基世界 2 - 环境变量配置

# ========== 基础配置 ==========
PROJECT_NAME=硅基世界 2
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ========== 数据库配置 ==========
DATABASE_URL=sqlite+aiosqlite:///./guiji_world_2.db
# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/guiji_world_2

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# ========== 向量数据库配置 ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ========== LLM 配置 ==========
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# OpenClaw 集成 (可选)
# OPENCLAW_WORKSPACE=C:\Users\97RPZ8T\.openclaw\workspace
# OPENCLAW_CHANNEL=webchat
# OPENCLAW_MODEL=bailian/qwen3.5-plus

# ========== 区块链配置 ==========
WEB3_RPC_URL=https://sepolia.infura.io/v3/your-key
WEB3_PRIVATE_KEY=your-private-key-here
IDENTITY_CONTRACT_ADDRESS=0x...
ECONOMY_CONTRACT_ADDRESS=0x...
NFT_CONTRACT_ADDRESS=0x...

# ========== x402 支付配置 ==========
X402_ENABLED=False
X402_API_KEY=

# ========== WebSocket 配置 ==========
WS_ENABLED=True
WS_HEARTBEAT_INTERVAL=60

# ========== 文件上传配置 ==========
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,png,gif,webp,pdf,doc,docx,txt

# ========== 邮件配置 (可选) ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/guiji-world-2.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
